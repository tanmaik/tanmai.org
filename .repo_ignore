# Default fallback .repo_ignore content
**/node_modules/
**/.npm/
**/.next/
**/temp/
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/

# Build caches
**/.gradle/
**/.nuget/
**/.cargo/
**/.stack-work/
**/.ccache/

# IDE and Editor caches
**/.idea/
**/.vscode/
**/*.swp
**/*~

# Temp files
**/*.tmp
**/*.temp
**/*.bak

# Image files
**/*.ico
**/*.png
**/*.jpeg
**/*.jpg

**/*.db
**/*.meta
**/package-lock.json
**/bun.lock